DATABASE_URL=postgresql://user:password@host:5432/fishdb
JWT_SECRET_KEY=change-this-to-a-long-random-string
PORT=5000

# Cloudinary — get these from cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email — optional, OTPs printed to console if not set
MAIL_USERNAME=yourapp@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# CORS — optional, defaults to all origins
# ALLOWED_ORIGINS=https://your-frontend-domain.com

# Vision AI — pick at least one provider
# ANTHROPIC_API_KEY=sk-ant-...       ← Claude (recommended, best accuracy)
# OPENAI_API_KEY=sk-...              ← OpenAI GPT-4o-mini
# Gemini keys — add as many as you have; quota exhaustion rotates to the next key
# GEMINI_API_KEY=AIza...
# GEMINI_API_KEY_1=AIza...
# GEMINI_API_KEY_2=AIza...
# GEMINI_API_KEY_3=AIza...
# Force a specific provider: claude | gemini | openai  (auto if not set)
# VISION_AI_PROVIDER=gemini

# ML thresholds — optional
# CONFIDENCE_HIGH=0.70
# CONFIDENCE_LOW=0.50
